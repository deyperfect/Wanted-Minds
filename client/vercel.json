{
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/fonts/(.*)", "dest": "/fonts/$1" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*\\.(js|css|png|jpg|jpeg|webp|svg|ico|woff|woff2|ttf))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}